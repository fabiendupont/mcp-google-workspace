{
  "server": {
    "read_only": false,
    "rate_limit_rpm": 120,
    "allowed_origins": ["internal.corp.com"],
    "credentials_file": "/path/to/credentials.json",
    "project_id": "my-project-123456"
  },
  "services": [
    {
      "name": "drive",
      "constraints": [
        {
          "param": "parents",
          "values": ["WRITABLE_FOLDER_ID"],
          "access": "read-write",
          "location": "body",
          "_comment": "All created files must land in this folder"
        },
        {
          "param": "parents",
          "values": ["READONLY_FOLDER_ID"],
          "access": "read-only",
          "location": "body",
          "_comment": "Can list files in this folder but not create or move files into it"
        }
      ]
    },
    {
      "name": "calendar",
      "constraints": [
        { "param": "calendarId", "values": ["primary"], "access": "read-write" },
        { "param": "calendarId", "values": ["company-holidays@group.calendar.google.com"], "access": "read-only" }
      ]
    },
    {
      "name": "gmail",
      "denied_methods": [
        "messages.delete",
        "messages.trash",
        "messages.batchDelete",
        "settings.updateAutoForwarding",
        "settings.delegates.create",
        "settings.forwardingAddresses.create"
      ]
    },
    {
      "name": "sheets",
      "read_only": true,
      "constraints": [
        { "param": "spreadsheetId", "values": ["1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms"], "access": "read-only" }
      ]
    },
    {
      "name": "docs",
      "constraints": [
        {
          "param": "documentId",
          "values": ["TEMPLATE_DOC_ID"],
          "access": "read-only",
          "mode": "protect",
          "_comment": "Prevent modification of the document template; reading named styles is allowed"
        }
      ]
    },
    {
      "name": "slides",
      "constraints": [
        {
          "param": "presentationId",
          "values": ["TEMPLATE_SLIDES_ID"],
          "access": "read-only",
          "mode": "protect",
          "_comment": "Prevent modification of the presentation template; reading layouts is allowed"
        }
      ]
    }
  ],
  "templates": [
    {
      "id": "TEMPLATE_SLIDES_ID",
      "name": "standard",
      "description": "Standard corporate presentation template"
    }
  ]
}
